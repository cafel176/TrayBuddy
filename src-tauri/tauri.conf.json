{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "traybuddy",
  "version": "0.1.2",
  "identifier": "com.traybuddy.cafel",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../mods": "mods",
      "../i18n": "i18n",
      "../mod-tool": "mod-tool",
      "../other-tool": "other-tool"
    },
    "windows": {
      "nsis": {
        "languages": ["English", "ChineseSimplified", "Japanese"],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "language": ["zh-CN", "en-US", "ja-JP"],
        "bannerPath": "icons/banner.bmp",
        "dialogImagePath": "icons/dialog.bmp"
      }
    }
  }
}
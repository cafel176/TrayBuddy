{
  "bubble": {
    "background": "linear-gradient(145deg, rgba(255, 255, 255, 0.78) 0%, rgba(233, 246, 255, 0.74) 35%, rgba(214, 234, 255, 0.70) 70%, rgba(200, 225, 252, 0.66) 100%)",
    "border": "1.5px solid rgba(35, 60, 95, 0.35)",
    "border_radius": "16px",
    "padding": "10px 14px",
    "min_width": "120px",
    "max_width": "380px",
    "color": "#223047",
    "font_size": "14px",
    "line_height": "1.55",
    "font_family": "\"Microsoft YaHei\", \"PingFang SC\", sans-serif",
    "box_shadow": "0 3px 12px rgba(60, 120, 200, 0.18), 0 1px 4px rgba(0, 0, 0, 0.04), inset 0 1px 0 rgba(255, 255, 255, 0.70)",
    "backdrop_filter": "blur(12px)",
    "decoration_top": {
      "content": "✦ ✧ ✦",
      "top": "4px",
      "right": "6px",
      "font_size": "9px",
      "color": "rgba(80, 150, 235, 0.40)",
      "letter_spacing": "3px"
    },
    "decoration_bottom": {
      "content": "⟡",
      "bottom": "4px",
      "left": "8px",
      "font_size": "12px",
      "color": "rgba(80, 150, 235, 0.28)"
    },
    "tail": {
      "size": "10px",
      "color": "rgba(214, 234, 255, 0.72)",
      "shadow": "0 2px 2px rgba(60, 120, 200, 0.18)"
    }
  },
  "branch": {
    "container": {
      "gap": "5px",
      "margin_top": "8px",
      "padding_top": "8px",
      "border_top": "1px dashed rgba(70, 130, 210, 0.32)"
    },
    "button": {
      "padding": "6px 6px 6px 30px",
      "min_width": "100px",
      "background": "linear-gradient(135deg, rgba(255, 255, 255, 0.76) 0%, rgba(226, 242, 255, 0.70) 100%)",
      "border": "1px solid rgba(40, 90, 150, 0.28)",
      "border_radius": "10px",
      "color": "#2b3a55",
      "font_size": "13px",
      "box_shadow": "0 1px 4px rgba(60, 120, 200, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.60)",
      "backdrop_filter": "blur(8px)"
    },
    "button_hover": {
      "background": "linear-gradient(135deg, rgba(220, 240, 255, 0.90) 0%, rgba(175, 215, 255, 0.86) 100%)",
      "border_color": "rgba(40, 110, 190, 0.55)",
      "box_shadow": "0 4px 14px rgba(60, 120, 200, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.70)",
      "color": "#d27a1a",
      "transform": "translateY(-2px)"
    },
    "button_active": {
      "background": "linear-gradient(135deg, rgba(205, 232, 255, 0.90) 0%, rgba(160, 205, 255, 0.86) 100%)",
      "box_shadow": "0 2px 6px rgba(60, 120, 200, 0.18), inset 0 1px 3px rgba(40, 90, 150, 0.12)",
      "transform": "translateY(0)"
    },
    "decoration_left": {
      "content": "⌕",
      "left": "8px",
      "font_size": "12px",
      "color": "rgba(60, 140, 230, 0.46)",
      "color_hover": "rgba(40, 110, 200, 0.82)"
    },
    "decoration_right": {
      "content": "·",
      "content_hover": "✦",
      "right": "8px",
      "font_size": "16px",
      "font_size_hover": "11px",
      "color": "rgba(70, 130, 210, 0.26)",
      "color_hover": "rgba(210, 122, 40, 0.62)"
    }
  }
}
{
  "bubble": {
    "background": "linear-gradient(160deg, rgba(220, 237, 235, 0.92) 0%, rgba(198, 222, 220, 0.88) 55%, rgba(176, 206, 205, 0.86) 100%)",
    "border": "1.5px solid rgba(115, 155, 154, 0.55)",
    "border_radius": "16px",
    "padding": "10px 14px",
    "min_width": "120px",
    "max_width": "380px",
    "color": "#2f2a24",
    "font_size": "14px",
    "line_height": "1.5",
    "font_family": "\"Microsoft YaHei\", \"PingFang SC\", sans-serif",
    "box_shadow": "0 6px 18px rgba(76, 94, 94, 0.18), 0 2px 6px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.55)",
    "backdrop_filter": "blur(8px)",
    "decoration_top": {
      "content": "✦ ✧ ✦",
      "top": "4px",
      "right": "6px",
      "font_size": "9px",
      "color": "rgba(60, 46, 32, 0.35)",
      "letter_spacing": "3px"
    },
    "decoration_bottom": {
      "content": "• • •",
      "bottom": "4px",
      "left": "8px",
      "font_size": "10px",
      "color": "rgba(60, 46, 32, 0.25)",
      "letter_spacing": "2px"
    },
    "tail": {
      "size": "10px",
      "color": "rgba(206, 228, 226, 0.9)",
      "shadow": "0 2px 2px rgba(76, 94, 94, 0.2)"
    }
  },
  "branch": {
    "container": {
      "gap": "5px",
      "margin_top": "8px",
      "padding_top": "8px",
      "border_top": "1px dashed rgba(120, 150, 150, 0.45)"
    },
    "button": {
      "padding": "6px 6px 6px 30px",
      "min_width": "100px",
      "background": "linear-gradient(135deg, rgba(232, 244, 243, 0.95) 0%, rgba(210, 232, 230, 0.9) 100%)",
      "border": "1px solid rgba(120, 150, 150, 0.45)",
      "border_radius": "10px",
      "color": "#3b2e22",
      "font_size": "13px",
      "box_shadow": "0 2px 6px rgba(76, 94, 94, 0.16), inset 0 1px 0 rgba(255, 255, 255, 0.55)",
      "backdrop_filter": "blur(6px)"
    },
    "button_hover": {
      "background": "linear-gradient(135deg, rgba(216, 235, 233, 0.98) 0%, rgba(186, 214, 212, 0.92) 100%)",
      "border_color": "rgba(92, 122, 122, 0.6)",
      "box_shadow": "0 6px 16px rgba(76, 94, 94, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.65)",
      "color": "#2f241b",
      "transform": "translateY(-2px)"
    },
    "button_active": {
      "background": "linear-gradient(135deg, rgba(200, 226, 224, 0.98) 0%, rgba(168, 202, 200, 0.92) 100%)",
      "box_shadow": "0 2px 6px rgba(76, 94, 94, 0.18), inset 0 1px 3px rgba(76, 94, 94, 0.18)",
      "transform": "translateY(0)"
    },
    "decoration_left": {
      "content": "◎",
      "left": "8px",
      "font_size": "12px",
      "color": "rgba(60, 46, 32, 0.35)",
      "color_hover": "rgba(60, 46, 32, 0.6)"
    },
    "decoration_right": {
      "content": "·",
      "content_hover": "✧",
      "right": "8px",
      "font_size": "16px",
      "font_size_hover": "11px",
      "color": "rgba(60, 46, 32, 0.28)",
      "color_hover": "rgba(60, 46, 32, 0.5)"
    }
  }
}
